        <!-- Payment Information -->
        <div class="payment-info">
            <div class="bank-card">
                <h3>
                    <span>💳</span> Thông tin nhận lương
                </h3>
                <div class="bank-details">
                    <div class="bank-name">Ngân hàng Vietcombank</div>
                    <div class="bank-account">1018 3456 789</div>
                    <div class="bank-holder">PHẠM HỒNG QUÝ</div>
                </div>
                <div class="tax-info">
                    <div class="tax-row">
                        <span>Mã số thuế:</span>
                        <span>123456789-01</span>
                    </div>
                    <div class="tax-row">
                        <span>Chi nhánh:</span>
                        <span>VCB - CN TP.HCM</span>
                    </div>
                    <div class="tax-row">
                        <span>Ngày trả lương:</span>
                        <span>Ngày 05 hàng tháng</span>
                    </div>
                </div>
            </div>

            <div class="payslip-card">
                <h3>
                    <span>📄</span> Bảng lương chi tiết
                </h3>
                <div class="payslip-list">
                    <div class="payslip-item" onclick="downloadPayslip('3-2026')">
                        <span class="payslip-month">Tháng 3/2026</span>
                        <span class="payslip-amount">10.500.000 ₫</span>
                        <span class="payslip-icon">📥</span>
                    </div>
                    <div class="payslip-item" onclick="downloadPayslip('2-2026')">
                        <span class="payslip-month">Tháng 2/2026</span>
                        <span class="payslip-amount">11.500.000 ₫</span>
                        <span class="payslip-icon">📥</span>
                    </div>
                    <div class="payslip-item" onclick="downloadPayslip('1-2026')">
                        <span class="payslip-month">Tháng 1/2026</span>
                        <span class="payslip-amount">13.000.000 ₫</span>
                        <span class="payslip-icon">📥</span>
                    </div>
                    <div class="payslip-item" onclick="downloadPayslip('12-2025')">
                        <span class="payslip-month">Tháng 12/2025</span>
                        <span class="payslip-amount">11.000.000 ₫</span>
                        <span class="payslip-icon">📥</span>
                    </div>
                </div>
            </div>
        </div>
    </main>

