<%- include('partials/header') %>
<link rel="stylesheet" href="css/ThuNhap.css">
    <main class="main-container">
        <!-- Page Title with Month Selector -->
        <div class="page-title">
            <div class="title-left">
                <span>💰</span>
                <h1>Xem thu nhập cá nhân</h1>
            </div>
            <div class="month-selector">
                <button class="month-nav" onclick="changeMonth(-1)">←</button>
                <span class="current-month" id="currentMonth">Tháng 3, 2026</span>
                <button class="month-nav" onclick="changeMonth(1)">→</button>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-icon">💰</div>
                </div>
                <div class="stat-value">12.500.000 ₫</div>
                <div class="stat-label">Tổng thu nhập</div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-icon">⏰</div>
                </div>
                <div class="stat-value">176 giờ</div>
                <div class="stat-label">Tổng giờ công</div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-icon">📊</div>
                </div>
                <div class="stat-value">22/26 ngày</div>
                <div class="stat-label">Ngày công thực tế</div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-icon">💳</div>
                </div>
                <div class="stat-value">10.500.000 ₫</div>
                <div class="stat-label">Thực nhận</div>

            </div>
        </div>

        <div class="salary-breakdown attendance-stats-card">
            <div class="section-header">
                <h2>
                    <span>📊</span> Thống kê chuyên cần tháng <span id="statMonthTitle">3/2026</span>
                </h2>
            </div>
 
            <div class="stats-grid" style="margin-top: 20px;">
                <div class="stat-card" style="border-left: 5px solid #3498db;">
                    <div class="stat-header">
                        <div class="stat-icon">📅</div>
                    </div>
                    <div class="stat-value" id="statTotalDays">0</div>
                    <div class="stat-label" style="font-weight: bold;">Tổng ngày đi làm</div>
                </div>

                <div class="stat-card" style="border-left: 5px solid #2ecc71;">
                    <div class="stat-header">
                        <div class="stat-icon">✅</div>
                    </div>
                    <div class="stat-value" id="statOnTime" style="color: #27ae60;">0</div>
                    <div class="stat-label">Số ngày đúng giờ</div>
                </div>

                <div class="stat-card" style="border-left: 5px solid #e74c3c;">
                    <div class="stat-header">
                        <div class="stat-icon">⚠️</div>
                    </div>
                    <div class="stat-value" id="statLate" style="color: #c0392b;">0</div>
                    <div class="stat-label">Số ngày đi trễ</div>
                </div>

                <div class="stat-card" style="border-left: 5px solid #f39c12;">
                    <div class="stat-header">
                        <div class="stat-icon">⏳</div>
                    </div>
                    <div class="stat-value" id="statOvertime" style="color: #d35400;">0</div>
                    <div class="stat-label">Số ngày tăng ca</div>
                </div>
            </div>
            
            <div class="breakdown-note" style="margin-top: 15px; color: #7f8c8d; font-style: italic;">
                * Dữ liệu được tổng hợp tự động từ lịch sử chấm công AI
            </div>
        </div>

        <!-- Attendance Stats -->
        <div class="attendance-stats">
            <div class="chart-card">
                <h3>
                    <span>📊</span> Giờ công theo ngày
                </h3>
                <div class="chart-container">
                    <div class="chart-bar-wrapper">
                        <div class="chart-bar" style="height: 160px"></div>
                        <span class="chart-label">T2</span>
                    </div>
                    <div class="chart-bar-wrapper">
                        <div class="chart-bar" style="height: 180px"></div>
                        <span class="chart-label">T3</span>
                    </div>
                    <div class="chart-bar-wrapper">
                        <div class="chart-bar" style="height: 170px"></div>
                        <span class="chart-label">T4</span>
                    </div>
                    <div class="chart-bar-wrapper">
                        <div class="chart-bar" style="height: 190px"></div>
                        <span class="chart-label">T5</span>
                    </div>
                    <div class="chart-bar-wrapper">
                        <div class="chart-bar" style="height: 175px"></div>
                        <span class="chart-label">T6</span>
                    </div>
                    <div class="chart-bar-wrapper">
                        <div class="chart-bar" style="height: 100px"></div>
                        <span class="chart-label">T7</span>
                    </div>
                    <div class="chart-bar-wrapper">
                        <div class="chart-bar" style="height: 80px"></div>
                        <span class="chart-label">CN</span>
                    </div>
                </div>
                <div class="chart-legend">
                    <div class="legend-item">
                        <div class="legend-color" style="background: #8e44ad"></div>
                        <span>Giờ làm</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-color" style="background: #e74c3c"></div>
                        <span>Giờ chuẩn: 8h</span>
                    </div>
                </div>
            </div>

            <div class="stats-summary">
                <h3>
                    <span>📈</span> Thống kê chấm công
                </h3>
                <div class="summary-circle">
                    <div class="circle-progress"></div>
                </div>
                <div class="circle-stats">
                    <div class="stat-row">
                        <span class="stat-name">Đi làm đúng giờ</span>
                        <span class="stat-number good">18 ngày</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-name">Đi trễ</span>
                        <span class="stat-number warning">2 ngày</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-name">Nghỉ phép</span>
                        <span class="stat-number">2 ngày</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-name">Tăng ca</span>
                        <span class="stat-number good">25 giờ</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-name">Tỷ lệ chuyên cần</span>
                        <span class="stat-number good">92%</span>
                    </div>
                </div>
            </div>
        </div>

