            </div>

            <!-- Main Content -->
            <div class="training-content">
                <div class="content-header">
                    <h2>Tài liệu phổ biến</h2>
                    <select class="sort-select" onchange="sortDocuments(this)">
                        <option>Mới nhất</option>
                        <option>Xem nhiều nhất</option>
                        <option>Tải nhiều nhất</option>
                        <option>A - Z</option>
                    </select>
                </div>

                <div class="documents-grid">
                    <div class="document-card" onclick="viewDocument(1)">
                        <div class="document-icon">📄</div>
                        <div class="document-info">
                            <h4>Quy trình chế biến Phở bò</h4>
                            <p>Hướng dẫn chi tiết từ khâu chọn nguyên liệu đến nấu nước dùng</p>
                            <div class="document-meta">
                                <span>📅 15/03/2026</span>
                                <span>👁️ 1.2k lượt xem</span>
                                <span>📥 350 tải</span>
                            </div>
                        </div>
                        <button class="download-btn" onclick="downloadDocument(1, event)">📥</button>
                    </div>

                    <div class="document-card" onclick="viewDocument(2)">
                        <div class="document-icon">📄</div>
                        <div class="document-info">
                            <h4>Quy tắc phục vụ bàn chuyên nghiệp</h4>
                            <p>10 bước phục vụ khách từ A-Z</p>
                            <div class="document-meta">
                                <span>📅 14/03/2026</span>
                                <span>👁️ 890 lượt xem</span>
                                <span>📥 234 tải</span>
                            </div>
                        </div>
                        <button class="download-btn" onclick="downloadDocument(2, event)">📥</button>
                    </div>

                    <div class="document-card" onclick="viewDocument(3)">
                        <div class="document-icon">📊</div>
                        <div class="document-info">
                            <h4>Quy trình vệ sinh nhà bếp</h4>
                            <p>Checklist vệ sinh hàng ngày, tuần, tháng</p>
                            <div class="document-meta">
                                <span>📅 13/03/2026</span>
                                <span>👁️ 2.1k lượt xem</span>
                                <span>📥 567 tải</span>
                            </div>
                        </div>
                        <button class="download-btn" onclick="downloadDocument(3, event)">📥</button>
                    </div>

                    <div class="document-card" onclick="viewDocument(4)">
                        <div class="document-icon">📝</div>
                        <div class="document-info">
                            <h4>Công thức Bún chả Hà Nội</h4>
                            <p>Công thức chuẩn vị Hà thành</p>
                            <div class="document-meta">
                                <span>📅 12/03/2026</span>
                                <span>👁️ 3.4k lượt xem</span>
                                <span>📥 890 tải</span>
                            </div>
                        </div>
                        <button class="download-btn" onclick="downloadDocument(4, event)">📥</button>
                    </div>
                </div>

                <!-- Video Section -->
                <div class="video-section">
                    <div class="section-header">
                        <h2>
                            <span>🎥</span> Video hướng dẫn
                        </h2>
                        <!-- <span class="view-all" onclick="viewAllVideos()">Xem tất cả →</span> -->
                    </div>
                    <div class="video-grid">
                        <div class="video-card" onclick="playVideo(1)">
                            <div class="video-thumbnail">
                                ▶️
                                <span class="video-duration">15:30</span>
                            </div>
                            <div class="video-info">
                                <h4>Kỹ thuật thái rau củ</h4>
                                <p>Hướng dẫn các kiểu thái cơ bản</p>
                                <div class="video-views">👁️ 2.5k lượt xem</div>
                            </div>
                        </div>
                        <div class="video-card" onclick="playVideo(2)">
                            <div class="video-thumbnail">
                                ▶️
                                <span class="video-duration">12:45</span>
                            </div>
                            <div class="video-info">
                                <h4>Pha chế nước chấm</h4>
                                <p>Công thức nước chấm cho 20 món</p>
                                <div class="video-views">👁️ 1.8k lượt xem</div>
                            </div>
                        </div>
                        <div class="video-card" onclick="playVideo(3)">
                            <div class="video-thumbnail">
                                ▶️
                                <span class="video-duration">20:15</span>
                            </div>
                            <div class="video-info">
                                <h4>Trang trí món ăn</h4>
                                <p>Kỹ thuật plating chuyên nghiệp</p>
                                <div class="video-views">👁️ 3.2k lượt xem</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

