    <!-- Document Viewer Modal -->
    <div class="modal" id="documentModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="modalTitle">Quy trình chế biến Phở bò</h3>
                <span class="close-modal" onclick="closeModal()">&times;</span>
            </div>
            <div class="document-viewer">
                <div class="document-preview">
                    <span>📄</span>
                    <p style="margin-top: 20px; color: #7f8c8d;">PDF - 2.5 MB</p>
                </div>
                <div class="document-actions">
                    <button class="view-btn" onclick="viewDocumentFull()">📖 Xem tài liệu</button>
                    <button class="download-btn-large" onclick="downloadCurrentDocument()">📥 Tải xuống</button>
                </div>
            </div>
        </div>
    </div>
