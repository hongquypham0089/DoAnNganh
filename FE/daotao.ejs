<%- include('partials/header') %>
<link rel="stylesheet" href="css/daotao.css">

    <main class="main-container">
        <!-- Page Title with Search -->
        <div class="page-title">
            <div class="title-left">
                <span>📚</span>
                <h1>Xem hướng dẫn về quy trình làm việc</h1>
            </div>
            <div class="search-box">
                <input type="text" placeholder="Tìm kiếm tài liệu, khóa học...">
                <button onclick="searchTraining()">🔍</button>
            </div>
        </div>

        <!-- Categories -->
        <div class="categories-section">
            <div class="section-header">
                <h2>
                    <span>📋</span> Danh mục đào tạo
                </h2>
                <!-- <span class="view-all" onclick="viewAllCategories()">Xem tất cả →</span> -->
            </div>
            <div class="categories-grid">
                <div class="category-card" onclick="selectCategory('che-bien')">
                    <div class="category-icon">🍳</div>
                    <h3>Quy trình chế biến</h3>
                    <p>Quy trình chuẩn trong chế biến món ăn</p>
                    <div class="document-count">24 tài liệu</div>
                </div>
                <div class="category-card" onclick="selectCategory('cong-thuc')">
                    <div class="category-icon">📝</div>
                    <h3>Công thức món ăn</h3>
                    <p>100+ công thức món ăn đặc sắc</p>
                    <div class="document-count">156 công thức</div>
                </div>
                <div class="category-card" onclick="selectCategory('phuc-vu')">
                    <div class="category-icon">🤵</div>
                    <h3>Quy tắc phục vụ</h3>
                    <p>Kỹ năng phục vụ chuyên nghiệp</p>
                    <div class="document-count">18 tài liệu</div>
                </div>
                <div class="category-card" onclick="selectCategory('ve-sinh')">
                    <div class="category-icon">🧹</div>
                    <h3>Vệ sinh an toàn</h3>
                    <p>An toàn thực phẩm & vệ sinh</p>
                    <div class="document-count">15 tài liệu</div>
                </div>
            </div>
        </div>

        <!-- Main Training Layout -->
        <div class="training-layout">
            <!-- Sidebar -->
            <div class="training-sidebar">
                <div class="sidebar-title">
                    <span>📂</span> Danh mục
                </div>
                <ul class="category-list" id="sidebarCategoryList">
                    <li style="text-align: center; color: #888;">Đang tải danh mục...</li>
                </ul>

