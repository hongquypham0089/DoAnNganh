<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Đăng nhập - Hệ thống chấm công thông minh</title>
    <link rel="stylesheet" href="css/dangnhap.css">
</head>
<body>
    <div class="bg-decoration">
        <div class="circle-1"></div>
        <div class="circle-2"></div>
        <div class="circle-3"></div>
    </div>

    <div class="login-container">
        <div class="login-card">
            <!-- Left Side - Branding -->
            <div class="login-brand">
                <div class="brand-icon">📸</div>
                <h1 class="brand-title">SmartCheck</h1>
                <p class="brand-subtitle">Hệ thống chấm công thông minh<br>ứng dụng AI nhận diện khuôn mặt</p>
                <ul class="brand-features">
                    <li><span>🔒</span> Nhận diện khuôn mặt chính xác</li>
                    <li><span>⏱️</span> Chấm công nhanh chóng</li>
                    <li><span>📊</span> Báo cáo chi tiết</li>
                    <li><span>🔐</span> Bảo mật tuyệt đối</li>
                </ul>
            </div>

            <!-- Right Side - Login Form -->
            <div class="login-form-side">
                <div class="form-header">
                    <h2>Đăng nhập</h2>
                    <p>Vui lòng nhập thông tin đăng nhập của bạn</p>
                </div>

                <!-- Error Message -->
                <div class="error-message" id="errorMessage">
                    <span>⚠️</span>
                    <span id="errorText">Sai tên đăng nhập hoặc mật khẩu</span>
                </div>

                <!-- Login Form -->
                <form class="login-form" id="loginForm" onsubmit="return false;">
                    <div class="input-group">
                        <label>Mã nhân viên / Email</label>
                        <div class="input-wrapper">
                            <span class="input-icon">👤</span>
                            <input type="text" id="username" placeholder="Nhập mã nhân viên hoặc email" autocomplete="off">
                        </div>
                    </div>

                    <div class="input-group">
                        <label>Mật khẩu</label>
                        <div class="input-wrapper">
                            <span class="input-icon">🔒</span>
                            <input type="password" id="password" placeholder="Nhập mật khẩu">
                            <button type="button" class="toggle-password" onclick="togglePassword()">👁️</button>
                        </div>
                    </div>

                    <div class="form-options">
                        <label class="remember-me">
                            <input type="checkbox" id="rememberMe">
                            <span>Ghi nhớ đăng nhập</span>
                        </label>
                        <a href="#" class="forgot-password" onclick="forgotPassword()">Quên mật khẩu?</a>
                    </div>

                    <button type="submit" class="login-btn" id="loginBtn" onclick="handleLogin()">Đăng nhập</button>
                </form>

                <div class="login-footer">
                    <p>© 2026 SmartCheck - Hệ thống chấm công thông minh</p>
                    <p style="margin-top: 5px;">Phiên bản 2.0</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Forgot Password Modal -->
    <div class="modal" id="forgotModal">
        <div class="modal-content">
            <div class="modal-icon">📧</div>
            <h3>Quên mật khẩu?</h3>
            <p>Vui lòng liên hệ bộ phận IT hoặc quản lý để được hỗ trợ đặt lại mật khẩu.</p>
            <button class="modal-btn" onclick="closeModal()">Đóng</button>
        </div>
    </div>

    <!-- Success Modal -->
    <div class="modal" id="successModal">
        <div class="modal-content">
            <div class="modal-icon">✅</div>
            <h3>Đăng nhập thành công!</h3>
            <p>Đang chuyển hướng đến trang chủ...</p>
        </div>
    </div>
    <script src="js/dangnhap.js"></script>
</body>
</html>